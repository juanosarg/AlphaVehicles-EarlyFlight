<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<Vehicles.VehicleTurretDef ParentName="VehicleTurretBase">
		<defName>AV_Avro504_MainTurret</defName>
		<label>light machine gun</label>
		<description>A light machine gun used by the gunner of the Avro 504. Inaccurate and uses up a lot of ammo.</description>
		<turretType>Rotatable</turretType>
		<shotSound>Shot_MachinePistol</shotSound>
		<projectile>Bullet_MachinePistol</projectile>
		<reloadTimer>3.5</reloadTimer>
		<warmUpTimer>0.4</warmUpTimer>
		<magazineCapacity>30</magazineCapacity>
		<genericAmmo>true</genericAmmo>
		<autoSnapTargeting>false</autoSnapTargeting>
		<rotationSpeed>1.95</rotationSpeed>
		<projectileOffset>2.1</projectileOffset>
		<minRange>2</minRange>
		<maxRange>32.9</maxRange>
	
		<fireModes>
			<li>
				<shotsPerBurst>12</shotsPerBurst>
				<ticksBetweenShots>8</ticksBetweenShots>
				<ticksBetweenBursts>90</ticksBetweenBursts>
				<spreadRadius>1</spreadRadius>
				<label>Burst</label>
				<texPath>UI/Gizmos/FireRate_Burst</texPath>
				<accuracyTouch>0.28</accuracyTouch>
				<accuracyShort>0.72</accuracyShort>
				<accuracyMedium>0.66</accuracyMedium>
				<accuracyLong>0.50</accuracyLong>
			</li>
			<li>
				<shotsPerBurst>1</shotsPerBurst>
				<ticksBetweenShots>10</ticksBetweenShots>
				<ticksBetweenBursts>20</ticksBetweenBursts>
				<label>Single</label>
				<texPath>UI/Gizmos/FireRate_Single</texPath>
				<accuracyTouch>0.28</accuracyTouch>
				<accuracyShort>0.72</accuracyShort>
				<accuracyMedium>0.66</accuracyMedium>
				<accuracyLong>0.50</accuracyLong>
			</li>
			
		</fireModes>
		<graphicData>
			<texPath>Things/Mote/Transparent</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>Cutout</shaderType>
			<drawSize>1</drawSize>
		</graphicData>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
	</Vehicles.VehicleTurretDef>
</Defs>