<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="BaseBullet">
		<defName>AV_Bomb</defName>
		<label>frag bomb</label>
		<graphicData>
			<texPath>Things/Projectile/AV_FragBomb</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
			<drawSize>3</drawSize>
		</graphicData>
		<thingClass>Projectile_Explosive</thingClass>
		<projectile>
			<damageDef>Bomb</damageDef>
			<speed>15</speed>
			<explosionRadius>8</explosionRadius>
			<flyOverhead>true</flyOverhead>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>MortarBomb_Explode</soundExplode>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
		</projectile>
	</ThingDef>
	<Vehicles.VehicleTurretDef ParentName="VehicleTurretBase">
		<defName>AV_HandleyPage_MainTurret</defName>
		<label>frag bomb</label>
		<description>Drop a huge fragmentation bomb.</description>
		<turretType>Static</turretType>
		<shotSound>MortarBomb_Explode</shotSound>
		<projectile>AV_Bomb</projectile>
		<reloadTimer>10</reloadTimer>
		<warmUpTimer>4.5</warmUpTimer>
		<magazineCapacity>5</magazineCapacity>
		<chargePerAmmoCount>1</chargePerAmmoCount>
		<genericAmmo>true</genericAmmo>
		<autoSnapTargeting>false</autoSnapTargeting>
		<rotationSpeed>1.2</rotationSpeed>
		
		<projectileOffset>2.5</projectileOffset>
	
		<maxRange>18</maxRange>
	
		
	
		<fireModes>
			<li>
				<shotsPerBurst>1~1</shotsPerBurst>
				<ticksBetweenBursts>10~10</ticksBetweenBursts>
				<forcedMissRadius>1</forcedMissRadius>
				<label>Frag bomb</label>
				<texPath>Things/Projectile/AV_FragBomb</texPath>
			</li>
		</fireModes>
		<graphicData>
			<texPath>Things/Mote/Transparent</texPath>
			<graphicClass>Vehicles.Graphic_Turret</graphicClass>
			<shaderType>Cutout</shaderType>
			<drawSize>(1, 1)</drawSize>
		</graphicData>
		<ammunition>
			<thingDefs>
				<li>Steel</li>
			</thingDefs>
		</ammunition>
		
	</Vehicles.VehicleTurretDef>
	
</Defs>